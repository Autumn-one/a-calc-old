    },
    "homepage": "https://github.com/Autumn-one/js-calc#readme",
    "dependencies": {
        "numbro": "^2.3.6"
    },
    "devDependencies": {
        "ts-loader": "^9.2.6",
        "ts-node": "^10.5.0",
        "webpack": "^5.69.1",
        "webpack-cli": "^4.9.2"
    }
}
